<Page
    x:Class="yomusic.Views.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mcuxc="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="24,24,24,0"
            FontSize="34"
            FontWeight="SemiBold"
            Text="Settings" />

        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled">
            <Grid>
                <StackPanel
                    x:Name="SettingsStack"
                    MaxWidth="1000"
                    Margin="24,12,24,140"
                    HorizontalAlignment="Stretch"
                    Spacing="{StaticResource SettingsCardSpacing}">


                    <!--  Playback  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Playback" />

                    <mcuxc:SettingsCard Description="Preferred streaming quality" Header="Audio Quality">
                        <mcuxc:SettingsCard.HeaderIcon>
                            <FontIcon FontFamily="{StaticResource MingCute}" Glyph="{StaticResource MgcMusic2Line}" />
                        </mcuxc:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="AudioQualityCombo" MinWidth="120" />
                    </mcuxc:SettingsCard>

                    <!--  Appearance  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Appearance" />

                    <mcuxc:SettingsCard Description="Choose light, dark, or system theme" Header="Theme">
                        <mcuxc:SettingsCard.HeaderIcon>
                            <FontIcon FontFamily="{StaticResource MingCute}" Glyph="{StaticResource MgcPaletteLine}" />
                        </mcuxc:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="ThemeCombo" MinWidth="120" />
                    </mcuxc:SettingsCard>

                    <mcuxc:SettingsCard Description="Enable UI animations" Header="Animations">
                        <mcuxc:SettingsCard.HeaderIcon>
                            <FontIcon FontFamily="{StaticResource MingCute}" Glyph="{StaticResource MgcMagic3Line}" />
                        </mcuxc:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="AnimToggle"
                            OffContent="Off"
                            OnContent="On" />
                    </mcuxc:SettingsCard>

                    <!--  Account  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Account" />

                    <mcuxc:SettingsCard x:Name="AccountCard" Header="Account">
                        <mcuxc:SettingsCard.HeaderIcon>
                            <FontIcon FontFamily="{StaticResource MingCute}" Glyph="{StaticResource MgcUser4Line}" />
                        </mcuxc:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <StackPanel x:Name="AccountInfoPanel" VerticalAlignment="Center" />
                            <Button
                                x:Name="SignOutBtn"
                                VerticalAlignment="Center"
                                Content="Logout" />
                        </StackPanel>
                    </mcuxc:SettingsCard>

                    <!--  Cache  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Cache" />

                    <mcuxc:SettingsCard Description="Cached lyrics and session data" Header="Cache">
                        <mcuxc:SettingsCard.HeaderIcon>
                            <FontIcon FontFamily="{StaticResource MingCute}" Glyph="{StaticResource MgcDeleteLine}" />
                        </mcuxc:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                x:Name="CacheSizeText"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                            <Button x:Name="ClearCacheBtn" Content="Clear" />
                        </StackPanel>
                    </mcuxc:SettingsCard>

                    <!--  About  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="About" />

                    <mcuxc:SettingsCard Description="A modern YouTube Music client for Windows" Header="YoMusic">
                        <mcuxc:SettingsCard.HeaderIcon>
                            <BitmapIcon ShowAsMonochrome="False" UriSource="ms-appx:///Assets/StoreLogo.scale-100.png" />
                        </mcuxc:SettingsCard.HeaderIcon>
                        <TextBlock
                            x:Name="VersionText"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            IsTextSelectionEnabled="True" />
                    </mcuxc:SettingsCard>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
