<Page
    x:Class="yomusic.Views.MoodsGenres"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer
            x:Name="PageScroll"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled">
            <StackPanel Padding="24,24,24,140" Spacing="28">
                <StackPanel Spacing="12">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            FontSize="34"
                            FontWeight="SemiBold"
                            Text="Moods &amp; Genres" />

                        <Button
                            x:Name="MoodsLeftBtn"
                            Grid.Column="1"
                            Width="40"
                            Height="40"
                            Margin="0,0,8,0"
                            Content="{StaticResource MgcLeftFill}"
                            CornerRadius="20"
                            FontFamily="{StaticResource MingCute}"
                            IsEnabled="False" />
                        <Button
                            x:Name="MoodsRightBtn"
                            Grid.Column="2"
                            Width="40"
                            Height="40"
                            Content="{StaticResource MgcRightFill}"
                            CornerRadius="20"
                            FontFamily="{StaticResource MingCute}"
                            IsEnabled="False" />
                    </Grid>

                    <ScrollViewer
                        x:Name="MoodsScrollViewer"
                        HorizontalScrollBarVisibility="Hidden"
                        HorizontalScrollMode="Disabled"
                        VerticalScrollMode="Disabled">
                        <Grid x:Name="MoodsGrid" />
                    </ScrollViewer>
                </StackPanel>

                <StackPanel x:Name="SectionList" Margin="0,-28,0,0">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                </StackPanel>

                <TextBlock
                    x:Name="EmptyText"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Text="No content found"
                    Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>

        <muxc:ProgressRing
            x:Name="LoadingRing"
            Width="40"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="True"
            Visibility="Visible" />
    </Grid>
</Page>
