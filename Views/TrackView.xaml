<Page
    x:Class="yomusic.Views.TrackView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.6*" />
            <ColumnDefinition Width="0.4*" />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Column="0"
            Margin="48,48,24,140"
            VerticalAlignment="Center"
            Spacing="20">
            <Border
                x:Name="CoverBorder"
                Width="300"
                Height="300"
                HorizontalAlignment="Center"
                Background="{ThemeResource SystemControlBackgroundBaseMediumBrush}"
                CornerRadius="12">
                <Image
                    x:Name="AlbumArt"
                    Stretch="UniformToFill"
                    Visibility="Collapsed" />
            </Border>

            <StackPanel>
                <TextBlock
                    x:Name="SongTitle"
                    FontSize="28"
                    FontWeight="SemiBold"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
                <TextBlock
                    x:Name="ArtistName"
                    FontSize="18"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Column="1" Margin="24,48,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel
                Margin="-16,0,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="0">
                <StackPanel.Resources>
                    <StaticResource x:Key="ButtonForeground" ResourceKey="SystemControlForegroundBaseLowBrush" />
                    <StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="SystemControlForegroundBaseHighBrush" />
                    <StaticResource x:Key="ButtonForegroundPressed" ResourceKey="SystemControlForegroundBaseHighBrush" />
                </StackPanel.Resources>
                <Button
                    x:Name="QueueTabBtn"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="OnQueueTabClick"
                    Content="Queue"
                    FontSize="16"
                    FontWeight="SemiBold" />
                <Button
                    x:Name="LyricsTabBtn"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="OnLyricsTabClick"
                    Content="Lyrics"
                    FontSize="16"
                    FontWeight="SemiBold" />
            </StackPanel>

            <ScrollViewer
                x:Name="QueuePanel"
                Grid.Row="1"
                Visibility="Visible">
                <StackPanel x:Name="QueueList" Margin="0,0,0,140">
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer
                x:Name="LyricsPanel"
                Grid.Row="1"
                Margin="0,16,0,0"
                VerticalScrollBarVisibility="Hidden"
                Visibility="Collapsed">
                <Grid>
                    <StackPanel
                        x:Name="LyricsStack"
                        Margin="0,0,16,180"
                        Spacing="8" />
                    <muxc:ProgressRing
                        x:Name="LyricsLoading"
                        Width="24"
                        Height="24"
                        Margin="0,0,16,180"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsActive="True"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="NoLyricsText"
                        Margin="0,0,16,180"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                        Text="No lyrics available"
                        Visibility="Collapsed" />
                </Grid>
            </ScrollViewer>
        </Grid>

        <muxc:ProgressRing
            x:Name="LoadingRing"
            Width="40"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="True"
            Visibility="Visible" />
    </Grid>
</Page>
