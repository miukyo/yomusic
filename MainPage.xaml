<Page
    x:Class="yomusic.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:yomusic.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:yomusic"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mcuxc="using:CommunityToolkit.WinUI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    KeyDown="OnPageKeyDown"
    muxc:BackdropMaterial.ApplyToRootOrPageBackground="True"
    mc:Ignorable="d">
    <Grid>
        <mcuxc:TitleBar
            x:Name="AppTitleBar"
            Title="YoMusic"
            VerticalAlignment="Top"
            AutoConfigureCustomTitleBar="True"
            BackButtonClick="appTitleBar_BackButtonClick"
            DisplayMode="Tall"
            IsBackButtonVisible="True"
            Subtitle="Beta">
            <mcuxc:TitleBar.Icon>
                <BitmapIcon ShowAsMonochrome="False" UriSource="ms-appx:///Assets/StoreLogo.scale-100.png" />
            </mcuxc:TitleBar.Icon>
            <mcuxc:TitleBar.Content>
                <controls:SearchBox x:Name="SearchBox" />
            </mcuxc:TitleBar.Content>
            <mcuxc:TitleBar.Footer>
                <Button
                    x:Name="ProfileButton"
                    Width="32"
                    Height="32"
                    Padding="0"
                    BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                    Click="OnProfileButtonClick"
                    CornerRadius="16">
                    <Button.Content>
                        <muxc:PersonPicture
                            x:Name="ProfilePicture"
                            Width="32"
                            Height="32"
                            Initials="AB"
                            ProfilePicture="ms-appx:///Assets/Avatar.png" />
                    </Button.Content>
                </Button>
            </mcuxc:TitleBar.Footer>
        </mcuxc:TitleBar>


        <!--
            This control has a higher z-order than AppTitleBar,
            so it receives user input.
        -->

        <muxc:NavigationView
            x:Name="NavView"
            Grid.Row="1"
            Margin="0,48,0,0"
            VerticalAlignment="Stretch"
            Canvas.ZIndex="1"
            CompactModeThresholdWidth="0"
            CompactPaneLength="80"
            ExpandedModeThresholdWidth="0"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="False"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            ItemInvoked="NavView_ItemInvoked"
            Loaded="NavView_Loaded"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="NavView_SelectionChanged">

            <muxc:NavigationView.Resources>
                <x:Double x:Key="NavigationViewItemOnLeftIconBoxWidth">0</x:Double>
                <x:Double x:Key="NavigationViewItemOnLeftMinHeight">72</x:Double>
            </muxc:NavigationView.Resources>

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Tag="Home">
                    <StackPanel
                        x:Name="HomePanel"
                        Margin="-9,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <ScaleTransform />
                        </StackPanel.RenderTransform>

                        <Grid
                            x:Name="HomeIconContainer"
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <FontIcon
                                x:Name="HomeIconOutline"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                Glyph="{StaticResource MgcHome4Line}" />
                            <FontIcon
                                x:Name="HomeIconFilled"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                Glyph="{StaticResource MgcHome4Fill}"
                                Opacity="0" />
                        </Grid>
                        <TextBlock
                            x:Name="HomeText"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                            Text="Home" />
                    </StackPanel>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="Explore">
                    <StackPanel
                        x:Name="ExplorePanel"
                        Margin="-9,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <ScaleTransform />
                        </StackPanel.RenderTransform>
                        <Grid
                            x:Name="ExploreIconContainer"
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <FontIcon
                                x:Name="ExploreIconOutline"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                Glyph="{StaticResource MgcCompassLine}" />
                            <FontIcon
                                x:Name="ExploreIconFilled"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                Glyph="{StaticResource MgcCompassFill}"
                                Opacity="0" />
                        </Grid>
                        <TextBlock
                            x:Name="ExploreText"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                            Text="Explore" />
                    </StackPanel>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="Library">
                    <StackPanel
                        x:Name="LibraryPanel"
                        Margin="-9,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <ScaleTransform />
                        </StackPanel.RenderTransform>
                        <Grid
                            x:Name="LibraryIconContainer"
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <FontIcon
                                x:Name="LibraryIconOutline"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                Glyph="{StaticResource MgcBook5Line}" />
                            <FontIcon
                                x:Name="LibraryIconFilled"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                Glyph="{StaticResource MgcBook5Fill}"
                                Opacity="0" />
                        </Grid>
                        <TextBlock
                            x:Name="LibraryText"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                            Text="Library" />
                    </StackPanel>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem Tag="Moods">
                    <StackPanel
                        x:Name="MoodsPanel"
                        Margin="-9,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <ScaleTransform />
                        </StackPanel.RenderTransform>
                        <Grid
                            x:Name="MoodsIconContainer"
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <FontIcon
                                x:Name="MoodsIconOutline"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                Glyph="{StaticResource MgcMagic3Line}" />
                            <FontIcon
                                x:Name="MoodsIconFilled"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                Glyph="{StaticResource MgcMagic3Fill}"
                                Opacity="0" />
                        </Grid>
                        <TextBlock
                            x:Name="MoodsText"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                            Text="Moods" />
                    </StackPanel>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>
            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem Tag="History">
                    <StackPanel
                        x:Name="HistoryPanel"
                        Margin="-9,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <ScaleTransform />
                        </StackPanel.RenderTransform>
                        <Grid
                            x:Name="HistoryIconContainer"
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <FontIcon
                                x:Name="HistoryIconOutline"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                Glyph="{StaticResource MgcHistoryLine}" />
                            <FontIcon
                                x:Name="HistoryIconFilled"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                Glyph="{StaticResource MgcHistoryFill}"
                                Opacity="0" />
                        </Grid>
                        <TextBlock
                            x:Name="HistoryText"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                            Text="History" />
                    </StackPanel>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Tag="Settings">
                    <StackPanel
                        x:Name="SettingsPanel"
                        Margin="-9,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <ScaleTransform />
                        </StackPanel.RenderTransform>
                        <Grid
                            x:Name="SettingsIconContainer"
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <FontIcon
                                x:Name="SettingsIconOutline"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                Glyph="{StaticResource MgcSettings3Line}" />
                            <FontIcon
                                x:Name="SettingsIconFilled"
                                FontFamily="{StaticResource MingCute}"
                                FontSize="24"
                                Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                Glyph="{StaticResource MgcSettings3Fill}"
                                Opacity="0" />
                        </Grid>
                        <TextBlock
                            x:Name="SettingsText"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                            Text="Settings" />
                    </StackPanel>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.FooterMenuItems>
            <muxc:NavigationView.Content>
                <Frame x:Name="ContentFrame" />
            </muxc:NavigationView.Content>
        </muxc:NavigationView>

        <Border
            MaxWidth="1400"
            Margin="96,0,16,16"
            Padding="12,12,40,12"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="{ThemeResource SystemControlAcrylicElementMediumHighBrush}"
            BorderBrush="{ThemeResource SystemControlBackgroundBaseLowRevealBorderBrush}"
            BorderThickness="0.5"
            Canvas.ZIndex="100"
            CornerRadius="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <Grid.Resources>
                    <Style x:Key="PlainButtonStyle" TargetType="Button">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Grid Background="{TemplateBinding Background}">
                                        <ContentPresenter
                                            x:Name="ContentPresenter"
                                            Content="{TemplateBinding Content}"
                                            RenderTransformOrigin="0.5,0.5">
                                            <ContentPresenter.RenderTransform>
                                                <ScaleTransform x:Name="ScaleTrans" ScaleX="1" ScaleY="1" />
                                            </ContentPresenter.RenderTransform>
                                        </ContentPresenter>
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal" />
                                                <VisualState x:Name="PointerOver" />
                                                <VisualState x:Name="Pressed">
                                                    <Storyboard>
                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleX">
                                                            <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0" />
                                                            <SplineDoubleKeyFrame KeyTime="0:0:0.10" Value="0.85" />
                                                            <SplineDoubleKeyFrame KeyTime="0:0:0.20" Value="1.0" />
                                                        </DoubleAnimationUsingKeyFrames>
                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleY">
                                                            <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0" />
                                                            <SplineDoubleKeyFrame KeyTime="0:0:0.10" Value="0.85" />
                                                            <SplineDoubleKeyFrame KeyTime="0:0:0.20" Value="1.0" />
                                                        </DoubleAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>

                <StackPanel
                    x:Name="TrackInfo"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Width="80"
                        Height="80"
                        Background="{ThemeResource SystemControlBackgroundBaseMediumBrush}"
                        CornerRadius="8">
                        <Image
                            x:Name="AlbumArt"
                            Source="ms-appx:///Assets/Unknown.png"
                            Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TrackTitle"
                            Width="150"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Song Title"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            x:Name="ArtistName"
                            Width="150"
                            FontSize="12"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            Text="Artist Name"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                    <StackPanel
                        Margin="0,0,0,2"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <StackPanel.Resources>
                            <Style BasedOn="{StaticResource PlainButtonStyle}" TargetType="Button">
                                <Setter Property="FontFamily" Value="{StaticResource MingCute}" />
                            </Style>
                        </StackPanel.Resources>

                        <Button
                            x:Name="ShuffleButton"
                            Margin="4,0"
                            Content="{StaticResource MgcShuffle2Fill}"
                            FontSize="24"
                            ToolTipService.ToolTip="Shuffle" />
                        <Button
                            x:Name="PreviousButton"
                            Margin="4,0"
                            Content="{StaticResource MgcSkipPreviousFill}"
                            FontSize="24"
                            ToolTipService.ToolTip="Previous" />
                        <Button
                            x:Name="PlayPauseButton"
                            Margin="8,0"
                            Content="{StaticResource MgcPlayFill}"
                            FontSize="42" />
                        <Button
                            x:Name="NextButton"
                            Margin="4,0"
                            Content="{StaticResource MgcSkipForwardFill}"
                            FontSize="24"
                            ToolTipService.ToolTip="Next" />
                        <Button
                            x:Name="RepeatButton"
                            Margin="4,0"
                            Content="{StaticResource MgcRepeatFill}"
                            FontSize="24"
                            ToolTipService.ToolTip="Repeat" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="CurrentTime"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            Text="0:00" />
                        <Slider
                            x:Name="ProgressSlider"
                            Grid.Column="1"
                            Margin="0"
                            VerticalAlignment="Center"
                            IsThumbToolTipEnabled="False"
                            Maximum="100"
                            Minimum="0"
                            Value="0" />
                        <TextBlock
                            x:Name="TotalTime"
                            Grid.Column="2"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            Text="3:45" />
                    </Grid>
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <StackPanel.Resources>
                        <Style BasedOn="{StaticResource PlainButtonStyle}" TargetType="Button">
                            <Setter Property="FontFamily" Value="{StaticResource MingCute}" />
                        </Style>
                    </StackPanel.Resources>
                    <Button
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Content="&#xE767;"
                        FontFamily="Segoe MDL2 Assets" />
                    <Slider
                        x:Name="VolumeSlider"
                        Width="100"
                        Margin="8,0,16,0"
                        VerticalAlignment="Center"
                        Maximum="100"
                        Minimum="0"
                        Value="70" />
                    <Button
                        x:Name="QueueButton"
                        Background="Transparent"
                        Content="&#xE14C;"
                        FontFamily="Segoe MDL2 Assets"
                        ToolTipService.ToolTip="Queue" />
                </StackPanel>
            </Grid>
        </Border>
        <Grid
            x:Name="LoginOverlay"
            Background="#80000000"
            Canvas.ZIndex="999"
            Tapped="OnLoginOverlayTapped"
            Visibility="Collapsed">
            <Border
                x:Name="LoginBorder"
                Width="650"
                Height="550"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                CornerRadius="8">
                <Grid x:Name="LoginWebViewGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button
                        Padding="8"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="OnLoginCloseClick"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" />
                    <muxc:WebView2 x:Name="LoginWebView2" Grid.Row="1" />
                    <StackPanel
                        x:Name="LoginProgressPanel"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                        <muxc:ProgressRing
                            x:Name="LoginProgressRing"
                            Width="40"
                            Height="40"
                            IsActive="False" />
                        <TextBlock
                            x:Name="LoginStatusText"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Page>